{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Agnitra",
  "favicon": "/favicon.svg",
  "github": "https://github.com/agnitraai/agnitraai",
  "colors": {
    "primary": "#ff4f5a",
    "light": "#f7f7f8",
    "dark": "#1f1f24"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Start Here",
            "pages": [
              "docs/index",
              "docs/intro/quickstart",
              "docs/intro/architecture"
            ]
          },
          {
            "group": "Product Guides",
            "pages": [
              "docs/guides/cli-and-sdk",
              "docs/guides/telemetry",
              "docs/guides/nvidia"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Platform",
            "pages": [
              "docs/reference/configuration",
              "docs/reference/control-plane",
              "docs/reference/responses-api"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/agnitraai/agnitraai",
          "icon": "github"
        },
        {
          "anchor": "PyPI",
          "href": "https://pypi.org/project/agnitra/",
          "icon": "python"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Quickstart",
        "href": "/docs/intro/quickstart"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/agnitraai/agnitraai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install",
      "href": "/docs/intro/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/agnitraai/agnitraai",
      "x": "https://x.com/agnitraai",
      "linkedin": "https://www.linkedin.com/company/agnitra-ai/"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/docs/index",
      "permanent": false
    }
  ],
  "ignore": ["deploy/**", "internal-docs/**"]
}
